from datetime import datetime

class EmotionDB:
    def __init__(self):
        self.data = []

    def add(self, emotion, confidence):
        record = {
            "id": len(self.data) + 1,
            "emotion": emotion,
            "confidence": confidence,
            "timestamp": datetime.now().isoformat()
        }

        self.data.append(record)
        return record

    def get_all(self):
        return self.data

    def clear(self):
        self.data = []